# EntroFeed Environment Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# Storage Configuration
# =============================================================================
# Storage handler: sqlite (default), tinydb, lmdb, hybrid
ENTROFEED_STORAGE_HANDLER=sqlite

# Data directory (all persistent data lives here)
DATA_DIR=./data
CONFIG_DIR=./configs

# =============================================================================
# LLM Providers Configuration
# =============================================================================
# Default LLM provider: dashscope, ollama, openai
DEFAULT_LLM_PROVIDER=dashscope

# ----- DashScope (Alibaba Qwen) - Recommended -----
# Get your API key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus
# Alternative models:
#   - qwen-turbo (fast, cheaper)
#   - qwen-plus (balanced, recommended)
#   - qwen-max (most capable)
#   - qwen-vl-max (vision model)
#   - qwen-coder-plus (code generation)

# ----- Ollama (Local Models) -----
# For Docker, use host.docker.internal to access host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# Default model
OLLAMA_MODEL=llama3
# Or use qwen3.5 for Chinese:
# OLLAMA_MODEL=qwen3.5:latest

# ----- OpenAI (Optional) -----
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# LiteLLM Gateway (Optional - for advanced routing)
# =============================================================================
USE_LITELLM_GATEWAY=false
LITELLM_GATEWAY_URL=http://localhost:4000
LITELLM_API_KEY=sk-litellm-default-key

# =============================================================================
# Application Settings
# =============================================================================
# RSS feed refresh interval (minutes)
REFRESH_INTERVAL=5

# Recent entries timeframe (hours)
RECENT_HOURS=36

# Base URL for RSS links (must be accessible from your network)
RSS_BASE_URL=http://localhost:8000

# =============================================================================
# Notification Handlers
# =============================================================================
# Uncomment and configure as needed:

# Slack
# SLACK_BOT_TOKEN=your_slack_bot_token
# SLACK_CHANNEL=rss

# Matrix
# MATRIX_HOMESERVER=http://matrix.example.com
# MATRIX_ROOM_ID=your_room_id
# MATRIX_USERNAME=your_username
# MATRIX_PASSWORD=your_password

# Ntfy
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOPIC=entrofeed

# Jira
# JIRA_SERVER=https://your-domain.atlassian.net
# JIRA_EMAIL=your_email
# JIRA_API_TOKEN=your_api_token
# JIRA_PROJECT_KEY=YOUR_PROJECT
